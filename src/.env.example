# ==============================================================================
# Production Environment Variables
# ==============================================================================
# Copy this file to .env and fill in real values before deploying
# ==============================================================================

# Database
POSTGRES_PASSWORD=change_me_to_secure_password

# JWT
JWT_SECRET=change_me_to_a_very_long_random_string_at_least_32_characters
JWT_ISSUER=nexus-ecommerce-platform
JWT_AUDIENCE=nexus-ecommerce-client

# Docker Registry (optional - for CI/CD)
DOCKER_REGISTRY=
TAG=latest
PLATFORM=linux

# PayOS (Payment Gateway)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Nexus E-Commerce
SMTP_FROM_EMAIL=

# URLs
WEB_RETURN_URL=https://your-domain.com/payment/success
WEB_CANCEL_URL=https://your-domain.com/payment/cancel
HANGFIRE_GATEWAY_URL=http://ocelot.apigw:80
