# React Client Environment Variables
# ============================================
# Copy this file to .env and fill in actual values
# DO NOT commit .env to version control

# API Gateway
# The base URL for all API calls to the backend microservices
# Development: localhost:5000 (API Gateway)
# Production: your-api-domain.com
VITE_API_BASE_URL=http://localhost:5000

# Google OAuth (Optional - if using Google login feature)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# GitHub OAuth (Optional - if using GitHub login feature)  
# Get from: https://github.com/settings/developers
VITE_GITHUB_CLIENT_ID=

# Feature Flags (Optional)
# Enable/disable analytics and error tracking
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false
