{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ElasticConfiguration": {
    "Uri": "http://localhost:9200"
  },
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyHere_MustBeAtLeast32Characters!",
    "Issuer": "nexus-ecommerce-platform",
    "Audience": "nexus-ecommerce-admin",
    "AccessTokenExpirationMinutes": 60
  },
  "MediaStorage": {
    "Provider": "Local",
    "Bucket": "nexus-media",
    "PublicBaseUrl": "",
    "S3": {
      "ServiceUrl": "",
      "AccessKey": "",
      "SecretKey": "",
      "Region": "ap-southeast-1",
      "ForcePathStyle": true
    },
    "LocalFallback": {
      "RootFolder": "wwwroot/images"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
